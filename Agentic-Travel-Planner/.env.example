# LLM API Keys
LLM_PROVIDER=openai
GOOGLE_MODEL=gemini-2.5-flash
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# External Service Keys (Optional - Mocks used if missing)
FLIGHT_API_KEY=your_amadeus_api_key_here
FLIGHT_API_SECRET=your_amadeus_api_secret_here
WEATHER_API_KEY=https://api.open-meteo.com/v1/forecast

# Payment Processing (Razorpay - Optional, uses mock if missing)
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Langfuse Observability (Optional - tracing disabled if missing)
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
