# LLM API Keys
LLM_PROVIDER=openai
GOOGLE_MODEL=gemini-2.5-flash
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# External Service Keys (Optional - local dataset remains the default fallback)
FLIGHT_PROVIDER=local
FLIGHT_API_KEY=your_amadeus_api_key_here
FLIGHT_API_SECRET=your_amadeus_api_secret_here
DUFFEL_API_TOKEN=your_duffel_api_token_here
DUFFEL_API_BASE_URL=https://api.duffel.com
DUFFEL_VERSION=v2
DUFFEL_TIMEOUT_SECONDS=15
AMADEUS_ENV=test
HOTEL_PROVIDER=local
SERPAPI_API_KEY=your_serpapi_api_key_here
SERPAPI_BASE_URL=https://serpapi.com/search.json
SERPAPI_TIMEOUT_SECONDS=20
SERPAPI_GL=in
SERPAPI_HL=en
SERPAPI_CURRENCY=INR
TRAIN_PROVIDER=rapidapi
TRAIN_API_KEY=your_rapidapi_key_here
TRAIN_API_BASE_URL=https://irctc1.p.rapidapi.com
TRAIN_RAPIDAPI_HOST=irctc1.p.rapidapi.com
TRAIN_SEARCH_PATH=/api/v3/trainBetweenStations
TRAIN_STATION_SEARCH_PATH=/api/v1/searchStation
TRAIN_TIMEOUT_SECONDS=15
WEATHER_API_KEY=https://api.open-meteo.com/v1/forecast

# ElevenLabs Voice (Optional - assistant voice playback)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_STABILITY=0.45
ELEVENLABS_SIMILARITY_BOOST=0.8
ELEVENLABS_STYLE=0.35
ELEVENLABS_SPEED=1.0
ELEVENLABS_USE_SPEAKER_BOOST=true

# Payment Processing (Razorpay - Optional, uses mock if missing)
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Langfuse Observability (Optional - tracing disabled if missing)
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
